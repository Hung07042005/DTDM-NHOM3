          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('Has container_id', function () {",
                  "  pm.expect(body).to.have.property('container_id');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
